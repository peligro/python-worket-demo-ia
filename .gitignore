# =============================================================================
# WORKER RAG PDF - .gitignore
# =============================================================================

# ------------------------------------------------------------------------------
# ENTORNO Y SECRETOS (NUNCA COMMIT)
# ------------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.env
secrets/
credentials.json
aws_credentials
*.pem
*.key

# ------------------------------------------------------------------------------
# PYTHON / PYCACHE
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ------------------------------------------------------------------------------
# VIRTUALENV / POETRY / PIPENV
# ------------------------------------------------------------------------------
# Virtual environments
venv/
ENV/
env/
.venv/

# Poetry
poetry.lock
.poetry/

# Pipenv
Pipfile.lock

# ------------------------------------------------------------------------------
# IDE / EDITORES
# ------------------------------------------------------------------------------
# VS Code
.vscode/
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml
*.ipr
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# ------------------------------------------------------------------------------
# TESTING / COVERAGE
# ------------------------------------------------------------------------------
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/

# ------------------------------------------------------------------------------
# LOGS / TEMPORALES
# ------------------------------------------------------------------------------
logs/
*.log
tmp/
temp/
*.tmp
*.temp
*.swp
*.swo
*~

# ------------------------------------------------------------------------------
# DOCKER / KUBERNETES (si se usan configs locales)
# ------------------------------------------------------------------------------
docker-compose.override.yml
*.local.yml
.kube/

# ------------------------------------------------------------------------------
# DOCUMENTACIÓN GENERADA
# ------------------------------------------------------------------------------
docs/_build/
*.pdf
*.html

# ------------------------------------------------------------------------------
# ESPECÍFICO DEL WORKER RAG
# ------------------------------------------------------------------------------
# Archivos PDF descargados temporalmente
*.pdf
*.PDF
temp_pdfs/

# Embeddings cache (si se genera localmente)
embeddings_cache/
*.npy
*.pt

# Modelos descargados (HuggingFace)
# Nota: el cache global va en docker/cache/huggingface, no aquí
.huggingface/
*.bin
*.safetensors

# ------------------------------------------------------------------------------
# SISTEMA OPERATIVO
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------------------------
# BACKUPS / COPIAS
# ------------------------------------------------------------------------------
*.bak
*.backup
*.old
