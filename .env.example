# =============================================================================
# WORKER RAG PDF - Variables de Entorno
# =============================================================================
# Copiar este archivo a .env y ajustar los valores para tu entorno.
# NUNCA commitear el archivo .env real al repositorio.
# =============================================================================

# ------------------------------------------------------------------------------
# ENTORNO Y LOGGING
# ------------------------------------------------------------------------------
ENVIRONMENT=local
# production, staging, development, local

LOG_LEVEL=INFO
# DEBUG, INFO, WARNING, ERROR, CRITICAL

# ------------------------------------------------------------------------------
# CONFIGURACIÓN DE COLAS (QUEUE PROVIDER)
# ------------------------------------------------------------------------------
# Proveedor de colas: redis, sqs, rabbitmq, kafka
QUEUE_PROVIDER=redis

# ------------------------------------------------------------------------------
# REDIS (para QUEUE_PROVIDER=redis)
# ------------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_STREAM=rag-jobs
REDIS_GROUP=rag-workers
# Timeout de conexión en segundos
REDIS_TIMEOUT=5
QUEUE_PROVIDERS=redis,sqs

# ✅ KAFKA (NUEVO)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_JOBS=rag-pdf-jobs
KAFKA_TOPIC_RESULTS=rag-pdf-results
KAFKA_CONSUMER_GROUP=rag-pdf-workers
# ------------------------------------------------------------------------------
# AWS SQS (para QUEUE_PROVIDER=sqs)
# Compatible con LocalStack para desarrollo local
# ------------------------------------------------------------------------------
COLA_SQS_RAG=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/cola-rag
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=fake
AWS_SECRET_ACCESS_KEY=fake
AWS_SECRET_ACCESS_URL=http://localstack:4566
# Visibility timeout en segundos (tiempo para procesar antes de re-encolar)
SQS_VISIBILITY_TIMEOUT=300
# Max mensajes a recibir por poll
SQS_MAX_MESSAGES=1

# ------------------------------------------------------------------------------
# BASE DE DATOS (compartida con API FastAPI)
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://laravel:secret@postgres:5432/fastapi
# Pool de conexiones (opcional, para producción)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ------------------------------------------------------------------------------
# PROCESAMIENTO RAG (compartido con API)
# ------------------------------------------------------------------------------
# Ruta para descargar PDFs temporalmente (si no se procesa en memoria)
PDF_TEMP_DIR=/tmp/rag-pdfs
# Chunk size para embeddings (debe coincidir con el modelo)
EMBEDDING_DIM=384
# Modelo de embeddings (sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2
# Límite de keywords por chunk
MAX_KEYWORDS=10

# ------------------------------------------------------------------------------
# S3 / OBJECT STORAGE (compartido con API)
# ------------------------------------------------------------------------------
S3_BUCKET_NAME=curso-udemy
AWS_BUCKET_URL=http://localhost:8000/
# Prefijo para archivos RAG dentro del bucket
S3_RAG_PREFIX=rag-pdfs/

# ------------------------------------------------------------------------------
| # CONFIGURACIÓN DEL WORKER
# ------------------------------------------------------------------------------
# Tiempo de bloqueo para dequeue en segundos (long polling)
WORKER_DEQUEUE_BLOCK=5
# Intervalo entre polls si no hay mensajes (segundos)
WORKER_POLL_INTERVAL=2
# Máximo de reintentos por job antes de marcar como fallido
WORKER_MAX_RETRIES=3
# Tiempo entre reintentos en segundos
WORKER_RETRY_DELAY=10

# ------------------------------------------------------------------------------
# MÉTRICAS Y MONITOREO (opcional)
# ------------------------------------------------------------------------------
# Habilitar métricas Prometheus
METRICS_ENABLED=false
METRICS_PORT=9091
# Endpoint para healthcheck del worker
HEALTHCHECK_PATH=/health